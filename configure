#!/bin/sh

R_SCRIPT="${R_HOME}/bin/Rscript"

RCPP_PARALLEL_CXXFLAGS=$("${R_SCRIPT}" -e "cat(RcppParallel::CxxFlags())" 2>/dev/null)

RCPP_PARALLEL_LIBDIR=$("${R_SCRIPT}" -e "cat(system.file('lib', package='RcppParallel'))" 2>/dev/null)
RCPP_PARALLEL_TBB_LIBDIR=$("${R_SCRIPT}" -e "cat(RcppParallel:::tbbLibraryPath())" 2>/dev/null)

RCPP_PARALLEL_LIBS=""
if [ -n "${RCPP_PARALLEL_LIBDIR}" ]; then
  if [ -f "${RCPP_PARALLEL_LIBDIR}/libRcppParallel.so" ]; then
    RCPP_PARALLEL_LIBS="${RCPP_PARALLEL_LIBS} -L${RCPP_PARALLEL_LIBDIR} -lRcppParallel"
  elif [ -f "${RCPP_PARALLEL_LIBDIR}/libRcppParallel.a" ]; then
    RCPP_PARALLEL_LIBS="${RCPP_PARALLEL_LIBS} -L${RCPP_PARALLEL_LIBDIR} -lRcppParallel"
  fi
fi

if [ -n "${RCPP_PARALLEL_TBB_LIBDIR}" ]; then
  RCPP_PARALLEL_LIBS="${RCPP_PARALLEL_LIBS} -L${RCPP_PARALLEL_TBB_LIBDIR} -Wl,-rpath,${RCPP_PARALLEL_TBB_LIBDIR} -ltbb -ltbbmalloc"
else
  RCPP_PARALLEL_LIBS="${RCPP_PARALLEL_LIBS} -ltbb -ltbbmalloc"
fi

sed -e "s|@RCPP_PARALLEL_CXXFLAGS@|${RCPP_PARALLEL_CXXFLAGS}|" \
    -e "s|@RCPP_PARALLEL_LIBS@|${RCPP_PARALLEL_LIBS}|" \
    src/Makevars.in > src/Makevars

exit 0
